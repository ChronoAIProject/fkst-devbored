#!/usr/bin/env node

import { appendFileSync } from 'node:fs'

const auditPath = process.env.FKST_HEALTH_TRIPWIRE_AUDIT
if (auditPath) {
  appendFileSync(
    auditPath,
    `${JSON.stringify({ argv: process.argv.slice(2), timestamp: new Date().toISOString() })}\n`,
    { encoding: 'utf8' },
  )
}
const exitOverride = process.env.FKST_HEALTH_TRIPWIRE_EXIT
if (exitOverride) {
  process.stderr.write(process.env.FKST_HEALTH_TRIPWIRE_STDERR ?? 'error: health command failed\n')
  process.exit(Number(exitOverride))
}
process.stdout.write(process.env.FKST_HEALTH_TRIPWIRE_VERDICT ?? 'HEALTHY\n')
