# This file is a reference only. The demo command needs none of these values.
# Export selected values in your shell before `pnpm start` or `pnpm dev`; this
# project does not automatically source .env files or place credentials in the
# browser. `pnpm dev` ignores FKST_CONSOLE_PORT and fixes the BFF at 8472 so its
# guarded Vite proxy has one documented target.

FKST_CONSOLE_PORT=8472
FKST_SANDBOX_REPO=OWNER/REPOSITORY
FKST_BOT_LOGIN=trusted-loop-agent
FKST_GH_BIN=gh

# Supply both observation values or neither. The durable root is read through
# `fkst-framework observe`; the console never opens delivery.redb directly.
FKST_OBSERVE_BIN=/path/to/fkst-framework
FKST_DURABLE_ROOT=/path/to/fkst-durable-root

# Optional opaque health command from the public devloop checkout.
FKST_HEALTH_SCRIPT=/path/to/fkst-packages/scripts/run.sh

# Omit by default. A value of 1 asks the root wrapper to supply the server's
# explicit --enable-writes flag; it does not bypass the exact sandbox repo,
# bot login, session token, Host/Origin, and distinct-human-actor guards.
FKST_ENABLE_WRITES=0
